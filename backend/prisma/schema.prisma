datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String
  phone       String?
  companyName String?
  role        String       @default("salesman")
  createdAt   DateTime     @default(now())
  attendance  Attendance[]
}

model Attendance {
  id      Int       @id @default(autoincrement())
  userId  Int
  timeIn  DateTime
  timeOut DateTime?
  lat     Float?
  lng     Float?
  status  String    @default("present")
  user    User      @relation(fields: [userId], references: [id])
}

model GpsLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  lat       Float
  lng       Float
  speed     Float?
  accuracy  Float?
  timestamp DateTime @default(now())
}
